{
  "name": "Machine",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "title": "Client",
      "relationType": "one-to-many",
      "relationEntity": "Client"
    },
    "brand": {
      "type": "string",
      "title": "Brand"
    },
    "model": {
      "type": "string",
      "title": "Model"
    },
    "serial_number": {
      "type": "string",
      "title": "Serial Number"
    },
    "refrigerant_type": {
      "type": "string",
      "title": "Refrigerant Type",
      "enum": [
        "R-134a",
        "R-1234yf"
      ]
    },
    "installation_date": {
      "type": "string",
      "format": "date",
      "title": "Installation Date"
    },
    "warranty_expiry": {
      "type": "string",
      "format": "date",
      "title": "Warranty Expiry"
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    }
  },
  "required": [
    "client_id",
    "brand",
    "model"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}